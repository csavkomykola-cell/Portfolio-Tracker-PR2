<Application
    x:Class="Portfolio_Tracker.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Portfolio_Tracker"
    StartupUri="Views/LoginWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Portfolio Tracker;component/Resources/Strings.uk.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="MainBackground" Color="#12121A" />
            <SolidColorBrush x:Key="CardBackground" Color="#1E1E2F" />
            <SolidColorBrush x:Key="TextColor" Color="White" />
            <SolidColorBrush x:Key="TableTextColor" Color="Black" />
            <SolidColorBrush x:Key="BlackColor" Color="Black" />
            <SolidColorBrush x:Key="SidebarHoverBackground" Color="#2E2E4F" />
            <SolidColorBrush x:Key="ButtonPrimaryBackground" Color="White" />
            <SolidColorBrush x:Key="ButtonPrimaryForeground" Color="Black" />
            <SolidColorBrush x:Key="ButtonDangerBackground" Color="#FF4C4C" />
            <SolidColorBrush x:Key="ButtonDangerForeground" Color="White" />

            <Style x:Key="SidebarButton" TargetType="Button">
                <Setter Property="Background" Value="#00FFFFFF" />
                <Setter Property="Foreground" Value="{DynamicResource TextColor}" />
                <Setter Property="Margin" Value="5" />
                <Setter Property="Padding" Value="10" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="BorderBrush" Value="Transparent" />

                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Setter.Value>
                </Setter>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5">

                                <ContentPresenter Margin="5" />
                            </Border>

                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource SidebarHoverBackground}" />

                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1.05" ScaleY="1.05" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>

                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>

                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="DataGrid">
                <Setter Property="Foreground" Value="{DynamicResource TableTextColor}" />
            </Style>

            <Style TargetType="DataGridRow">
                <Setter Property="Foreground" Value="{DynamicResource TableTextColor}" />
            </Style>

            <Style TargetType="DataGridCell">
                <Setter Property="Foreground" Value="{DynamicResource TableTextColor}" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Foreground" Value="{DynamicResource TableTextColor}" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>