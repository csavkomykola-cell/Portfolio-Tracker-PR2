<Page
    x:Class="Portfolio_Tracker.Views.PortfolioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource MainBackground}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="0,0,0,12"
            FontSize="28"
            FontWeight="Bold"
            Foreground="{DynamicResource TextColor}"
            Text="Портфель" />

        <Border
            Grid.Row="1"
            Padding="12"
            Background="{DynamicResource CardBackground}"
            BorderBrush="#2E2E4F"
            BorderThickness="1"
            CornerRadius="8"
            SnapsToDevicePixels="True">
            <StackPanel>

                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="14"
                    Foreground="{DynamicResource TextColor}"
                    Text="Мій портфель" />

                <DataGrid
                    Margin="10"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    CanUserSortColumns="False"
                    Foreground="{DynamicResource TableTextColor}"
                    GridLinesVisibility="All"
                    IsReadOnly="True"
                    ItemsSource="{Binding PortfolioItems}"
                    RowHeaderWidth="0"
                    SelectionChanged="DataGrid_SelectionChanged">

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="{DynamicResource TableTextColor}" />
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="{DynamicResource TableTextColor}" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Symbol}"
                            Header="Символ" />
                        <DataGridTextColumn
                            Width="2*"
                            Binding="{Binding Name}"
                            Header="Назва" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Quantity}"
                            Header="Кількість" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding AvgPrice}"
                            Header="Сер. ціна" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding CurrentPrice}"
                            Header="Поточна ціна" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding TotalValue}"
                            Header="Вартість" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Profit}"
                            Header="П/З" />
                    </DataGrid.Columns>

                </DataGrid>
            </StackPanel>
        </Border>

    </Grid>
</Page>