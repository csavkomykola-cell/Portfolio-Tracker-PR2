<Page
    x:Class="Portfolio_Tracker.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#12121A">

    <ScrollViewer>
        <StackPanel Margin="20">

            <TextBlock
                Margin="0,0,0,20"
                FontSize="28"
                FontWeight="Bold"
                Foreground="White"
                Text="Головна" />

            <WrapPanel>

                <Border
                    Width="250"
                    Margin="10"
                    Padding="20"
                    Background="#1E1E2F"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="Gray" Text="Загальна вартість" />
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding TotalValue}" />
                    </StackPanel>
                </Border>

                <Border
                    Width="250"
                    Margin="10"
                    Padding="20"
                    Background="#1E1E2F"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="Gray" Text="Прибуток" />
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="LightGreen"
                            Text="{Binding Profit}" />
                    </StackPanel>
                </Border>

                <Border
                    Width="250"
                    Margin="10"
                    Padding="20"
                    Background="#1E1E2F"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="Gray" Text="Активи" />
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding AssetCount}" />
                    </StackPanel>
                </Border>

            </WrapPanel>

            <Border
                Grid.Row="2"
                Margin="10"
                Padding="12"
                Background="#1E1E2F"
                BorderBrush="#2E2E4F"
                BorderThickness="1"
                CornerRadius="8"
                SnapsToDevicePixels="True">

                <StackPanel>

                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="20"
                        Foreground="White"
                        Text="Останні активи" />

                    <DataGrid
                        AutoGenerateColumns="False"
                        Background="Transparent"
                        BorderThickness="0"
                        CanUserSortColumns="False"
                        Foreground="#1E1E2F"
                        IsReadOnly="True"
                        ItemsSource="{Binding Assets}">

                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Symbol}"
                                Header="Символ" />
                            <DataGridTextColumn
                                Width="2*"
                                Binding="{Binding Name}"
                                Header="Назва" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding CurrentPrice}"
                                Header="Ціна" />
                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>

            </Border>

        </StackPanel>
    </ScrollViewer>

</Page>