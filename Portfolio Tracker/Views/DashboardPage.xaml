<Page
    x:Class="Portfolio_Tracker.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#12121A">

    <ScrollViewer>
        <StackPanel Margin="20">

            <TextBlock
                Margin="0,0,0,20"
                FontSize="28"
                FontWeight="Bold"
                Foreground="White"
                Text="Головна" />

            <WrapPanel>

                <Border
                    Width="250"
                    Margin="10"
                    Padding="20"
                    Background="#1E1E2F"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="Gray" Text="Загальна вартість" />
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding TotalValue}" />
                    </StackPanel>
                </Border>

                <Border
                    Width="250"
                    Margin="10"
                    Padding="20"
                    Background="#1E1E2F"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="Gray" Text="Прибуток" />
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="LightGreen"
                            Text="{Binding Profit}" />
                    </StackPanel>
                </Border>

                <Border
                    Width="250"
                    Margin="10"
                    Padding="20"
                    Background="#1E1E2F"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="Gray" Text="Активи" />
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="{Binding AssetCount}" />
                    </StackPanel>
                </Border>

            </WrapPanel>

            <TextBlock
                Margin="10"
                FontSize="20"
                Foreground="White"
                Text="Останні активи" />

            <DataGrid
                Margin="10"
                AutoGenerateColumns="False"
                Background="#1E1E2F"
                CanUserSortColumns="False"
                Foreground="#1E1E2F"
                ItemsSource="{Binding Assets}">

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Symbol}" Header="Символ" />
                    <DataGridTextColumn Binding="{Binding Name}" Header="Назва" />
                    <DataGridTextColumn Binding="{Binding CurrentPrice}" Header="Ціна" />
                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>
    </ScrollViewer>

</Page>