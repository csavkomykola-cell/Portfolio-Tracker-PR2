<Window
    x:Class="Portfolio_Tracker.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Вхід"
    Width="350"
    Height="400"
    Background="{DynamicResource MainBackground}"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock
                Margin="0,0,0,20"
                FontSize="24"
                FontWeight="Bold"
                Foreground="{DynamicResource TextColor}"
                Text="{DynamicResource LogInPage}" />

            <TextBlock
                FontSize="15"
                Foreground="{DynamicResource TextColor}"
                Text="{DynamicResource LogIn}" />
            <TextBox Margin="0,5,0,10" FontSize="15" />

            <TextBlock
                FontSize="15"
                Foreground="{DynamicResource TextColor}"
                Text="{DynamicResource Password}" />
            <PasswordBox Margin="0,5,0,15" FontSize="15" />

            <Button
                Margin="0,0,0,10"
                Padding="10"
                Background="{DynamicResource CardBackground}"
                Click="Login_Click"
                Content="{DynamicResource LogInPage}"
                FontSize="15"
                Foreground="{DynamicResource TextColor}" />

            <Button
                Margin="0,0,0,10"
                Padding="10"
                Background="{DynamicResource CardBackground}"
                Click="Register_Click"
                Content="{DynamicResource Register}"
                FontSize="15"
                Foreground="{DynamicResource TextColor}" />

            <Button
                Padding="10"
                Background="#4CAF50"
                Click="Guest_Click"
                Content="{DynamicResource GuestMode}"
                FontSize="15"
                Foreground="White" />

        </StackPanel>

    </Grid>
</Window>