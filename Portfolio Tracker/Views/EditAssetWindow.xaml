<Window
    x:Class="Portfolio_Tracker.Views.EditAssetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Редагування активу"
    Width="300"
    Height="330"
    Background="{DynamicResource MainBackground}"
    WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">

        <TextBlock
            FontSize="15"
            Foreground="{DynamicResource TextColor}"
            Text="{DynamicResource Symbol}" />
        <TextBox Margin="0,5,0,10" Text="{Binding Symbol}" />

        <TextBlock
            FontSize="15"
            Foreground="{DynamicResource TextColor}"
            Text="{DynamicResource Name}" />
        <TextBox Margin="0,5,0,10" Text="{Binding Name}" />

        <TextBlock
            FontSize="15"
            Foreground="{DynamicResource TextColor}"
            Text="{DynamicResource Type}" />
        <TextBox Margin="0,5,0,10" Text="{Binding AssetType}" />

        <TextBlock
            FontSize="15"
            Foreground="{DynamicResource TextColor}"
            Text="{DynamicResource Currency}" />
        <TextBox Margin="0,5,0,10" Text="{Binding Currency}" />

        <Button
            Margin="0,10,0,0"
            Background="{DynamicResource CardBackground}"
            Click="Save_Click"
            Content="{DynamicResource Save}"
            FontSize="15"
            Foreground="{DynamicResource TextColor}" />

    </StackPanel>
</Window>