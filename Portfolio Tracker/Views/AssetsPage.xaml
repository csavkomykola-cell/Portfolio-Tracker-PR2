<Page
    x:Class="Portfolio_Tracker.Views.AssetsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource MainBackground}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="0,0,0,20"
            FontSize="28"
            FontWeight="Bold"
            Foreground="{DynamicResource TextColor}"
            Text="{DynamicResource Assets}" />

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,15"
            Orientation="Horizontal">

            <Button
                Margin="5"
                Padding="8"
                Background="{DynamicResource ButtonPrimaryBackground}"
                Click="Add_Click"
                Content="{DynamicResource AddTransaction}"
                FontSize="15"
                Foreground="{DynamicResource ButtonPrimaryForeground}" />

            <Button
                Margin="5"
                Padding="8"
                Background="{DynamicResource ButtonPrimaryBackground}"
                Click="Edit_Click"
                Content="{DynamicResource Edit}"
                FontSize="15"
                Foreground="{DynamicResource ButtonPrimaryForeground}" />

            <Button
                Margin="5"
                Padding="8"
                Background="{DynamicResource ButtonDangerBackground}"
                Click="Delete_Click"
                Content="{DynamicResource Delete}"
                FontSize="15"
                Foreground="{DynamicResource ButtonDangerForeground}" />

        </StackPanel>

        <Border
            Grid.Row="2"
            Padding="12"
            Background="{DynamicResource CardBackground}"
            BorderBrush="#2E2E4F"
            BorderThickness="1"
            CornerRadius="8">

            <DataGrid
                x:Name="AssetsGrid"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                CanUserSortColumns="False"
                FontSize="15"
                Foreground="{DynamicResource TableTextColor}"
                IsReadOnly="True"
                ItemsSource="{Binding Assets}"
                SelectedItem="{Binding SelectedAsset}">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{DynamicResource TableTextColor}" />
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="{DynamicResource TableTextColor}" />
                        <Setter Property="BorderThickness" Value="0" />
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Symbol}"
                        Header="{DynamicResource Symbol}" />
                    <DataGridTextColumn
                        Width="2*"
                        Binding="{Binding Name}"
                        Header="{DynamicResource Name}" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding AssetType}"
                        Header="{DynamicResource AssetType}" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Currency}"
                        Header="{DynamicResource Currency}" />
                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>
</Page>