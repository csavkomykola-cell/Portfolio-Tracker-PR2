<Window
    x:Class="Portfolio_Tracker.Views.RegisterWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="{DynamicResource Register}"
    Width="420"
    Height="420"
    Background="{DynamicResource MainBackground}"
    Loaded="Window_Loaded"
    Opacity="0"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">

    <Border
        Margin="14"
        Padding="16"
        Background="{DynamicResource CardBackground}"
        BorderBrush="#2E2E4F"
        BorderThickness="1"
        CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                FontSize="20"
                FontWeight="Bold"
                Foreground="{DynamicResource TextColor}"
                Text="{DynamicResource Register}" />

            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                <TextBlock
                    FontSize="14"
                    Foreground="{DynamicResource TextColor}"
                    Text="{DynamicResource Username}" />
                <TextBox
                    x:Name="UsernameText"
                    Margin="0,6,0,12"
                    FontSize="14" />

                <TextBlock
                    FontSize="14"
                    Foreground="{DynamicResource TextColor}"
                    Text="{DynamicResource FullName}" />
                <TextBox
                    x:Name="FullNameText"
                    Margin="0,6,0,12"
                    FontSize="14" />

                <TextBlock
                    FontSize="14"
                    Foreground="{DynamicResource TextColor}"
                    Text="{DynamicResource Password}" />
                <PasswordBox
                    x:Name="PasswordBox"
                    Margin="0,6,0,12"
                    FontSize="14" />

                <TextBlock
                    FontSize="14"
                    Foreground="{DynamicResource TextColor}"
                    Text="Confirm password" />
                <PasswordBox
                    x:Name="ConfirmBox"
                    Margin="0,6,0,12"
                    FontSize="14" />

                <Button
                    x:Name="SaveButton"
                    Width="120"
                    Margin="6"
                    Padding="8"
                    Background="{DynamicResource ButtonPrimaryBackground}"
                    Click="SaveButton_Click"
                    Content="{DynamicResource Save}"
                    Foreground="{DynamicResource ButtonPrimaryForeground}" />
            </StackPanel>

            <TextBlock
                Grid.Row="2"
                Margin="0,8,0,0"
                HorizontalAlignment="Center"
                FontSize="12"
                Foreground="{DynamicResource TextColor}"
                Text="{DynamicResource Title}" />
        </Grid>
    </Border>
</Window>