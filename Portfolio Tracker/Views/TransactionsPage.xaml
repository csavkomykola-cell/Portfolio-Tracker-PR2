<Page
    x:Class="Portfolio_Tracker.Views.TransactionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource MainBackground}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="0,0,0,20"
            FontSize="28"
            FontWeight="Bold"
            Foreground="{DynamicResource TextColor}"
            Text="{DynamicResource Transactions}" />

        <Button
            Grid.Row="1"
            Margin="0,0,0,15"
            Padding="10"
            Background="{DynamicResource CardBackground}"
            Click="AddTransaction_Click"
            Content="{DynamicResource AddTransaction}"
            FontSize="15"
            Foreground="{DynamicResource TextColor}" />

        <Border
            Grid.Row="2"
            Padding="12"
            Background="{DynamicResource CardBackground}"
            BorderBrush="#2E2E4F"
            BorderThickness="1"
            CornerRadius="8">

            <DataGrid
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                CanUserSortColumns="False"
                FontSize="15"
                Foreground="{DynamicResource TableTextColor}"
                IsReadOnly="True"
                ItemsSource="{Binding Transactions}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{DynamicResource TableTextColor}" />
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="{DynamicResource TableTextColor}" />
                        <Setter Property="BorderThickness" Value="0" />
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Type}"
                        Header="{DynamicResource Type}" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Asset}"
                        Header="{DynamicResource Asset}" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Quantity}"
                        Header="{DynamicResource Quantity}" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Price}"
                        Header="{DynamicResource Price}" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Date}"
                        Header="{DynamicResource Date}" />
                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>
</Page>